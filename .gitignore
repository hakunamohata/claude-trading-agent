# Secrets — never commit
.env
*.key

# User-specific config (holdings, account IDs, rules) — never commit
user_config.py

# Data cache + scan/judgment outputs — all user-specific or large binaries
data/*.parquet
data/scans/
data/judgments/
# data/snapshots/ contains portfolio judgments with cost basis — never commit
data/snapshots/
# data/research/ contains per-ticker web research output (could be tied to user's portfolio)
data/research/
# data/news/ contains per-ticker headline summaries (could leak which names user owns)
data/news/
# data/options/ daily option chain snapshots (could leak holdings)
data/options/
# data/multi_agent/ cached judgment results
data/multi_agent/

# Personal holdings — never commit
holdings/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE
.vscode/
.idea/
