# Secrets — never commit
.env
*.key

# User-specific config (holdings, account IDs, rules) — never commit
user_config.py
# Timestamped backups (created by sync-holdings) — also contain holdings data
user_config.backup_*.py
*.backup_*.xlsx

# Data cache + scan/judgment outputs — all user-specific or large binaries
data/*.parquet
data/scans/
data/judgments/
# data/snapshots/ contains portfolio judgments with cost basis — never commit
data/snapshots/
# data/research/ contains per-ticker web research output (could be tied to user's portfolio)
data/research/
# data/news/ contains per-ticker headline summaries (could leak which names user owns)
data/news/
# data/options/ daily option chain snapshots (could leak holdings)
data/options/
# data/multi_agent/ cached judgment results
data/multi_agent/
# data/backtest/ LB backtest results computed against user's holdings
data/backtest/
# data/scratchpad/ JSONL scratchpads of multi-agent calls — leaks holdings
data/scratchpad/
# data/ticker_analysis/ on-demand deep panel runs from the dashboard
data/ticker_analysis/

# Personal planning notes (contain portfolio sizes, holdings names)
agentstock.md

# Personal holdings — never commit
holdings/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE
.vscode/
.idea/

# Project-scoped skills — user-local invocation playbooks
.claude/skills/
.claude/settings.local.json
